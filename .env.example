# Supabase (frontend client). Get these from the Supabase dashboard
# under Project Settings → API. The publishable/anon key is safe to ship
# in the client bundle — RLS policies enforce per-user access on the
# server side. Edge Functions are reachable at
# `${VITE_SUPABASE_URL}/functions/v1/<function-name>` and the auth header
# is forwarded automatically.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_or_legacy_anon_key
