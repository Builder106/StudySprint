# Supabase (frontend client). Get these from the Supabase dashboard
# under Project Settings → API Keys. Publishable keys (sb_publishable_…)
# are safe to ship in the client bundle — RLS policies enforce per-user
# access on the server side. Edge Functions are reachable at
# `${VITE_SUPABASE_URL}/functions/v1/<function-name>` and the auth
# header is forwarded automatically.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_…

# Secret key (sb_secret_…) — only needed for `deno task test:setup`
# (the e2e fixture bootstrap). Never used by the running app or the
# running test suite. Pull from Supabase dashboard → Project Settings →
# API Keys, "Secret key" row. .env is gitignored.
# SUPABASE_SECRET_KEY=
